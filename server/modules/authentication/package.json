{
  "name": "warzone-authentication-module",
  "version": "0.1.0",
  "private": true,
  "description": "Nakama runtime module: account provisioning, nickname claims, and Firebase-backed authentication hooks for Project Warzone.",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --outfile=build/index.js --format=iife --platform=node --target=es2020",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test $(find src -name '*.test.ts')"
  },
  "devDependencies": {
    "esbuild": "^0.23.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "@types/node": "^22.10.0"
  }
}